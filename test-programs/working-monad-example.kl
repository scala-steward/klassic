// Working higher-kinded Monad example

typeclass Monad<'m: * => *> where {
  bind: ('m<'a>, ('a) => 'm<'b>) => 'm<'b>;
  unit: ('a) => 'm<'a>
}

instance Monad<List> where {
  def bind(xs: List<'a>, f: ('a) => List<'b>): List<'b> = f(head(xs))
  def unit(x: 'a): List<'a> = [x]
}

def pairWithNext<'m>(xs: 'm<Int>): 'm<Int> where Monad<'m> = {
  bind(xs, (x) => unit(x + 1))
}

println(pairWithNext([1, 2, 3]))
